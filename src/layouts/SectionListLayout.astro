---
import BaseLayout from './BaseLayout.astro';

interface ListItem {
  id: string;
  title: string;
  description?: string;
  image?: string;
  date?: Date;
}

interface Props {
  title: string;
  description?: string;
  items: ListItem[];
  basePath: string;
}

const { title, description, items, basePath } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <header class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-4">{title}</h1>
      {description && (
        <div class="prose prose-lg mx-auto dark:prose-invert">
          <p>{description}</p>
        </div>
      )}
    </header>

    <slot name="before-list" />

    {items.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {items.map((item) => (
          <article class="group relative overflow-hidden rounded-lg border border-neutral-200 dark:border-neutral-700 hover:shadow-xl transition-all duration-300 bg-white dark:bg-neutral-800">
            {item.image ? (
              <div class="flex flex-col h-full">
                {/* Image Section */}
                <div class="relative overflow-hidden h-48">
                  <img
                    src={item.image}
                    alt={item.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
                    loading="lazy"
                  />
                  {/* Hover Overlay */}
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-end justify-center pb-4">
                    <div class="text-white text-center">
                      <div class="bg-white/20 backdrop-blur-sm rounded-full p-2 mb-1 mx-auto w-fit">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                      </div>
                      <span class="text-sm font-medium">Learn More</span>
                    </div>
                  </div>
                </div>

                {/* Content Section */}
                <div class="p-5 flex flex-col flex-grow">
                  {item.date && (
                    <time class="text-sm text-neutral-500 dark:text-neutral-400 mb-2 block">
                      {item.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  )}
                  <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                    <a href={`${basePath}${item.id}/`} class="stretched-link">{item.title}</a>
                  </h2>
                  {item.description && (
                    <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-3 flex-grow line-clamp-3">{item.description}</p>
                  )}
                  <div class="mt-auto pt-3">
                    <span class="inline-flex items-center text-sm text-primary-600 dark:text-primary-400 font-medium group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors">
                      Learn More
                      <span class="ml-1 group-hover:translate-x-1 transition-transform">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </span>
                    </span>
                  </div>
                </div>
              </div>
            ) : (
              <div class="flex flex-col h-full p-5">
                {/* Icon Placeholder */}
                <div class="w-14 h-14 bg-primary-100 dark:bg-primary-900/30 rounded-lg flex items-center justify-center mb-3 group-hover:bg-primary-200 dark:group-hover:bg-primary-900/50 transition-colors">
                  <svg class="w-7 h-7 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                </div>

                {item.date && (
                  <time class="text-sm text-neutral-500 dark:text-neutral-400 mb-2 block">
                    {item.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                )}
                <h2 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                  <a href={`${basePath}${item.id}/`} class="stretched-link">{item.title}</a>
                </h2>
                {item.description && (
                  <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-3 flex-grow line-clamp-3">{item.description}</p>
                )}
                <div class="mt-auto pt-3">
                  <span class="inline-flex items-center text-sm text-primary-600 dark:text-primary-400 font-medium group-hover:text-primary-700 dark:group-hover:text-primary-300 transition-colors">
                    Learn More
                    <span class="ml-1 group-hover:translate-x-1 transition-transform">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </span>
                </div>
              </div>
            )}
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <div class="mx-auto w-24 h-24 bg-neutral-100 dark:bg-neutral-800 rounded-full flex items-center justify-center mb-4">
          <svg class="w-12 h-12 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h3 class="text-xl font-medium text-neutral-900 dark:text-neutral-100 mb-2">No Content Yet</h3>
        <p class="text-neutral-600 dark:text-neutral-400">Check back soon for updates.</p>
      </div>
    )}

    <slot name="after-list" />
  </div>
</BaseLayout>

<style>
  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
</style>
