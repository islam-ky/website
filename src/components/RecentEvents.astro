---
import { getCollection } from 'astro:content';

const events = (await getCollection('events'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.eventDate.getTime() - a.data.eventDate.getTime())
  .slice(0, 3);
---

<section class="py-12 bg-white dark:bg-neutral-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold">Upcoming Events</h2>
      <a href="/news-and-events/" class="text-primary-600 dark:text-primary-400 hover:underline font-medium">
        View All &rarr;
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {events.map((event) => (
        <a
          href={`/events/${event.id}/`}
          class="group block bg-neutral-50 dark:bg-neutral-700 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-neutral-200 dark:border-neutral-600 hover:-translate-y-1"
        >
          {event.data.image && (
            <div class="h-48 overflow-hidden">
              <img
                src={event.data.image}
                alt={event.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-5">
            <div class="flex items-center gap-2 text-sm text-primary-600 dark:text-primary-400 mb-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time>
                {event.data.eventDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
            <h3 class="text-lg font-bold group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-1">
              {event.data.title}
            </h3>
            <div class="flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{event.data.eventTime}</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400 mt-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{event.data.location}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
