---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Get in touch with the Islamic Society of Cayman Islands">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-10 text-center">
      <h1 class="text-4xl font-bold mb-4">Contact Us</h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">Get in touch with the Islamic Society of Cayman Islands</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Contact Info -->
      <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-md p-8 border border-neutral-200 dark:border-neutral-700">
        <h2 class="text-2xl font-bold mb-6">Get In Touch</h2>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <div class="p-3 bg-primary-100 dark:bg-primary-900/50 rounded-lg">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Address</h3>
              <p class="text-neutral-600 dark:text-neutral-400 text-sm">Mercy Road, George Town, Grand Cayman, Cayman Islands</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="p-3 bg-primary-100 dark:bg-primary-900/50 rounded-lg">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Phone</h3>
              <a href="tel:+13453292079" class="text-primary-600 dark:text-primary-400 hover:underline">+1 (345) 329-2079</a>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <div class="p-3 bg-primary-100 dark:bg-primary-900/50 rounded-lg">
              <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold mb-1">Email</h3>
              <a href="mailto:isci@candw.ky" class="text-primary-600 dark:text-primary-400 hover:underline">isci@candw.ky</a>
            </div>
          </li>
        </ul>
      </div>

      <!-- Map or additional content -->
      <div class="bg-white dark:bg-neutral-800 rounded-xl shadow-md p-8 border border-neutral-200 dark:border-neutral-700">
        <h2 class="text-2xl font-bold mb-6">Visit Us</h2>
        <div class="rounded-lg overflow-hidden">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3632.7!2d-81.38!3d19.30!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDE4JzAwLjAiTiA4McKwMjInNDguMCJX!5e0!3m2!1sen!2sky!4v1"
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="ISCI Location"
            class="rounded-lg"
          ></iframe>
        </div>
        <div class="mt-4">
          <h3 class="font-semibold mb-2">Prayer Times</h3>
          <p class="text-sm text-neutral-600 dark:text-neutral-400">
            For current prayer times, please visit our <a href="/" class="text-primary-600 dark:text-primary-400 hover:underline">home page</a> or contact us.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
