---
import SectionListLayout from '../../layouts/SectionListLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('pages'))
  .filter((p) => !p.data.draft)
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    image: p.data.featured_image,
  }));
---

<SectionListLayout
  title="Pages"
  description="Browse our pages for more information about ISCI and the community."
  items={items}
  basePath="/pages/"
/>
