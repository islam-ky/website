{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "eventDate": {
      "type": "string",
      "format": "date-time"
    },
    "eventTime": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "eventDate",
    "eventTime",
    "location"
  ]
}