{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "featured_image": {
      "type": "string"
    },
    "images": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "menu": {
      "type": "object",
      "properties": {
        "main": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "weight": {
              "type": "number"
            },
            "identifier": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "weight"
          ]
        }
      },
      "required": [
        "main"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}